    "db:migrate:postgres:core": "node scripts/run-postgres-migration.js 0001_core_postgres.sql",
    "db:migrate:postgres:sync": "node scripts/run-postgres-migration.js 0002_sync_checkpoints.sql",
    "db:migrate:postgres:events": "node scripts/run-postgres-migration.js 0003_sync_events.sql",
    "db:migrate:postgres:sync-failures": "node scripts/run-postgres-migration.js 0004_sync_failure_handling.sql",
