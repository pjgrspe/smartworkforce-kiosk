# ── Central server connection ────────────────────────────────────────────────
# The base URL of your central SmartWorkforce API server (no trailing slash)
CENTRAL_URL=http://51.79.255.147

# Tenant code for this branch (must match what is registered on the central server)
TENANT_CODE=DEWEBNET

# ── Local service ports ───────────────────────────────────────────────────────
PORT=4000
WS_PORT=4001

# ── Sync intervals ────────────────────────────────────────────────────────────
# How often (ms) to try syncing punches to central and refreshing employee cache
SYNC_INTERVAL_MS=30000

# How often (ms) to refresh face encodings from central (default: 10 min)
ENCODING_REFRESH_INTERVAL_MS=600000

# ── Auto-updater ──────────────────────────────────────────────────────────────
# Git tag prefix for this kiosk. MUST match the client this kiosk belongs to.
#   ABG  → TAG_PREFIX=abg-v
#   SPCF → TAG_PREFIX=spcf-v
# Prevents the auto-updater from checking out the wrong client's release tags.
TAG_PREFIX=

# ── SQLite path ───────────────────────────────────────────────────────────────
DB_PATH=./data/kiosk.db
