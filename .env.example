# ============================================
# SUPABASE CONFIGURATION
# ============================================
# Get these from your Supabase project settings
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ============================================
# WEBSOCKET SERVER
# ============================================
WS_PORT=8080
WS_HOST=localhost

# ============================================
# AI ENGINE CONFIGURATION
# ============================================
# Camera device index (0 for default camera)
CAMERA_INDEX=0

# Minimum confidence threshold for face recognition (0.0 - 1.0)
# Lower values = more lenient matching, higher values = stricter matching
CONFIDENCE_THRESHOLD=0.6

# Frame rate for camera capture
FPS=15

# Camera resolution
FRAME_WIDTH=640
FRAME_HEIGHT=480

# Cooldown period to prevent duplicate check-ins (minutes)
RECOGNITION_COOLDOWN_MINUTES=5

# ============================================
# OFFLINE SYNC CONFIGURATION
# ============================================
# Delay between sync retry attempts (milliseconds)
SYNC_RETRY_DELAY_MS=5000

# Maximum number of retry attempts before flagging for manual review
SYNC_MAX_RETRIES=5

# How often to check Supabase connectivity (milliseconds)
CONNECTIVITY_CHECK_INTERVAL_MS=10000

# NeDB auto-compaction interval (milliseconds) - 24 hours
NEDB_COMPACTION_INTERVAL_MS=86400000

# ============================================
# LOGGING CONFIGURATION
# ============================================
# Log level: error, warn, info, debug
LOG_LEVEL=info

# Log file path
LOG_FILE_PATH=logs/apollo.log

# Number of log files to retain
LOG_MAX_FILES=30

# Max size of each log file (10MB)
LOG_MAX_SIZE=10485760

# ============================================
# ENVIRONMENT
# ============================================
NODE_ENV=production

# ============================================
# OPTIONAL: EMAIL NOTIFICATIONS
# ============================================
# Uncomment to enable email alerts for system errors
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# ALERT_EMAIL=admin@example.com
