# ============================================
# MONGODB CONFIGURATION
# ============================================
# MongoDB Atlas: mongodb+srv://user:pass@cluster.mongodb.net/apollo?retryWrites=true&w=majority
# Local:         mongodb://localhost:27017/apollo
MONGODB_URI=mongodb://localhost:27017/apollo

# ============================================
# HTTP API SERVER
# ============================================
HTTP_PORT=3000
# Comma-separated origins allowed by CORS (use * for dev)
CORS_ORIGIN=http://localhost:5173

# ============================================
# JWT CONFIGURATION
# ============================================
# CHANGE THIS to a long random string in production!
JWT_SECRET=change_me_to_a_strong_random_secret
JWT_EXPIRES_IN=12h

# ============================================
# WEBSOCKET SERVER
# ============================================
WS_PORT=8080
WS_HOST=localhost

# ============================================
# AI ENGINE CONFIGURATION
# ============================================
CAMERA_INDEX=0
CONFIDENCE_THRESHOLD=0.6
FPS=15
FRAME_WIDTH=640
FRAME_HEIGHT=480
RECOGNITION_COOLDOWN_MINUTES=5

# ============================================
# OFFLINE SYNC CONFIGURATION
# ============================================
SYNC_RETRY_DELAY_MS=5000
SYNC_MAX_RETRIES=5
CONNECTIVITY_CHECK_INTERVAL_MS=10000
NEDB_COMPACTION_INTERVAL_MS=86400000

# ============================================
# LOGGING CONFIGURATION
# ============================================
LOG_LEVEL=info
LOG_FILE_PATH=logs/apollo.log
LOG_MAX_FILES=30


# Max size of each log file (10MB)
LOG_MAX_SIZE=10485760

# ============================================
# ENVIRONMENT
# ============================================
NODE_ENV=production

# ============================================
# OPTIONAL: EMAIL NOTIFICATIONS
# ============================================
# Uncomment to enable email alerts for system errors
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# ALERT_EMAIL=admin@example.com
